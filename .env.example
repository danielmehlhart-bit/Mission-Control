# Environment Variables for Mission Control

# Directory paths (used by API routes)
BRIEFINGS_DIR=/home/hartner/.openclaw/workspace
MEMORY_DIR=/home/hartner/.openclaw/workspace

# Optional: Port configuration
PORT=3000

# Optional: Node environment
NODE_ENV=production

# Voice reply generation
# production defaults to hermes-cli; local development defaults to stub
MC_VOICE_REPLY_STRATEGY=hermes-cli
MC_VOICE_HERMES_COMMAND=hermes
MC_VOICE_HERMES_TIMEOUT_MS=45000
# default stub fallback keeps calls usable if the Hermes CLI is unavailable
MC_VOICE_REPLY_FALLBACK=stub

# Optional higher quality TTS
# MC_VOICE_TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=
# MC_VOICE_ELEVENLABS_VOICE_ID=

# Telegram → Voice recent-context bridge
# Shared bearer token for POST /api/voice/handoffs/telegram/context
MC_VOICE_BRIDGE_TOKEN=

# OpenAI Realtime WebRTC voice-to-voice
OPENAI_API_KEY=
MC_VOICE_REALTIME_MODEL=gpt-realtime-2
MC_VOICE_REALTIME_REASONING_EFFORT=low
MC_VOICE_REALTIME_VOICE=cedar
# Server-side live web search for voice calls (Responses API web_search)
MC_VOICE_WEB_SEARCH_MODEL=gpt-5.5
